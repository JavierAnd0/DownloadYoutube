# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Binary paths ──────────────────────────────────────────────────
# Leave empty to auto-detect (Windows local dev) or set path explicitly
YTDLP_BIN=
FFMPEG_BIN=

# ── YouTube PO Token (bot detection bypass) ───────────────────────
# Set to the bgutil service URL when running with docker-compose.
# The bgutil-ytdlp-pot-provider sidecar generates tokens automatically
# using a headless browser — no Google account required.
# Leave empty for local dev without the sidecar (YouTube may work anyway).
BGUTIL_HTTP_ENDPOINT=http://bgutil:4416

# ── Optional: path to cookies.txt for age-restricted content ──────
# YTDLP_COOKIES=/app/cookies.txt

# ── Directories (relative to project root) ────────────────────────
DOWNLOADS_DIR=downloads
UPLOADS_DIR=uploads

# ── File upload limits ────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# ── Security ──────────────────────────────────────────────────────
# Set to true when behind a reverse proxy (Nginx, Traefik, Caddy)
TRUST_PROXY=false
